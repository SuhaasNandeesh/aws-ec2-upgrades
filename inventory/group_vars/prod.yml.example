---
# Per-group vars for the prod account group.
# Copy to prod.yml and adjust.
#
# The profile name must match a profile in ~/.aws/config that assumes a role
# into this account via source_profile + role_arn chaining.
# Example ~/.aws/config:
#   [profile prod]
#   source_profile = default
#   role_arn = arn:aws:iam::111122223333:role/ec2-patch-automation

aws_profile: prod
aws_region: "ap-south-1"

# SSM connection plugin reads these (not the custom vars above)
ansible_aws_ssm_profile: "{{ aws_profile }}"
ansible_aws_ssm_region: "{{ aws_region }}"

# S3 bucket in this account for SSM module file transfer
ssm_bucket_name: ""  # e.g. "prod-ssm-patch-transfer"